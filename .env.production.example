APP_ENV=production
APP_DEBUG=false

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=

DATABASE_URL=postgresql+psycopg://username:password@host:5432/product_mvp

BACKEND_URL=https://api.your-domain.com
FRONTEND_URL=https://your-domain.com
FRONTEND_ORIGIN=https://your-domain.com
WS_URL=wss://api.your-domain.com/ws
MAIN_HOST=your-domain.com
ADMIN_HOST=admin.your-domain.com
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax

SECRET_KEY=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=change_this_password

NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.com
NEXT_PUBLIC_WS_URL=wss://api.your-domain.com/ws
SMTP_HOST=smtp.your-mail.com
SMTP_PORT=465
SMTP_USER=mailer@your-domain.com
SMTP_PASSWORD=replace_with_real_password
SMTP_FROM_EMAIL=no-reply@your-domain.com
SMTP_USE_TLS=false
SMTP_USE_SSL=true
AUTH_CODE_EXPIRE_MINUTES=10
AUTH_CHALLENGE_EXPIRE_MINUTES=10
AUTH_CHALLENGE_RATE=0.15
AUTH_CHALLENGE_FAIL_THRESHOLD=2
SHOPIFY_STORE_BASE_URL=https://your-store.myshopify.com
SHOPIFY_CLIENT_ID=your_shopify_client_id
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret
SHOPIFY_APP_URL=https://api.your-domain.com
SHOPIFY_ADMIN_ACCESS_TOKEN=your_shopify_admin_access_token
SHOPIFY_OAUTH_REDIRECT_URI=https://api.your-domain.com/api/v1/market/connect/shopify/callback
SHOPIFY_OAUTH_SCOPES=read_products,read_orders
SHOPIFY_EXECUTION_MODE=real
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password
DATAFORSEO_BASE_URL=https://api.dataforseo.com
BING_WEBMASTER_API_KEY=your_bing_webmaster_api_key
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
GOOGLE_ADS_CLIENT_ID=your_google_ads_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_ads_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_google_ads_refresh_token
GOOGLE_ADS_CUSTOMER_ID=your_google_ads_customer_id
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your_google_ads_login_customer_id
GOOGLE_OAUTH_REDIRECT_URI=https://api.your-domain.com/api/v1/market/connect/google/callback
AMAZON_PAAPI_ACCESS_KEY=your_amazon_paapi_access_key
AMAZON_PAAPI_SECRET_KEY=your_amazon_paapi_secret_key
AMAZON_PAAPI_PARTNER_TAG=your_partner_tag
AMAZON_PAAPI_REGION=us-east-1
AMAZON_PAAPI_HOST=webservices.amazon.com
AMAZON_OAUTH_CLIENT_ID=your_amazon_oauth_client_id
AMAZON_OAUTH_CLIENT_SECRET=your_amazon_oauth_client_secret
AMAZON_OAUTH_REDIRECT_URI=https://api.your-domain.com/api/v1/market/connect/amazon/callback
TIKTOK_MARKETING_ACCESS_TOKEN=your_tiktok_marketing_access_token
TIKTOK_ADVERTISER_ID=your_tiktok_advertiser_id
TIKTOK_APP_ID=your_tiktok_app_id
TIKTOK_APP_SECRET=your_tiktok_app_secret
TIKTOK_OAUTH_REDIRECT_URI=https://api.your-domain.com/api/v1/market/connect/tiktok/callback
META_ACCESS_TOKEN=your_meta_access_token
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token
TOKEN_ENCRYPTION_KEY=generate_a_fernet_key_here
