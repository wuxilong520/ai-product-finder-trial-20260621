{
  "manifest_version": 3,
  "name": "商航AI供应链助手",
  "version": "1.0.0",
  "description": "用户主动把1688公开商品信息同步到商航AI",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "https://*.1688.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "商航AI供应链助手"
  },
  "content_scripts": [
    {
      "matches": ["https://*.1688.com/*"],
      "js": ["security.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
